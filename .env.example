# Локальные параметры разработки (пример)
# Скопируйте в `.env` и заполните. Файл `.env` не коммитится.

# Bearer-токен SingularityApp API (из https://me.singularity-app.com)
SINGCTL_TOKEN=

# Base URL API (без завершающего /)
API_BASE_URL=https://api.singularity-app.com

# Опционально: путь к конфигу singctl для smoke
# SINGCTL_CONFIG=

# Go / codegen
# OAPI_CODEGEN=$(shell go env GOPATH)/bin/oapi-codegen
